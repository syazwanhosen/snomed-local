# Copy to .env and edit as needed:  cp .env.example .env

# Image versions (override to pin specific releases)
ES_VERSION=8.11.1
SNOWSTORM_VERSION=latest
BROWSER_VERSION=latest

# JVM heap sizes
# Raise if you have RAM to spare; lower for laptops with <16GB total memory.
# ES and Snowstorm together can comfortably consume 6-8GB during full-edition imports.
ES_HEAP=2g
SNOWSTORM_HEAP_MIN=2g
SNOWSTORM_HEAP_MAX=4g
